# Buildroot config for STM32F429I-DISCO with adbd
#
# Merges rota1001/stm32f429-linux (kernel+bootloader+romfs+SPI4-MMC+USB gadget)
# with adbd-cross (local noMMU adbd package).
#
# Toolchain: ARM Cortex-M4, FLAT, uClibc-ng.
# Kernel:   Linux 7.0 XIP from on-chip flash, DWC2 USB gadget, SPI4 MMC rootfs.
# Rootfs:   romfs in flash + ext2 on TF card (mounted by custom init).
# Packages: busybox (minimal), zlib, adbd.

# --- Architecture / toolchain ---
BR2_arm=y
BR2_cortex_m4=y
BR2_BINFMT_FLAT=y
BR2_PACKAGE_HOST_LINUX_HEADERS_CUSTOM_6_19=y
BR2_PTHREADS=y
# BR2_UCLIBC_INSTALL_UTILS is not set
BR2_ENABLE_LTO=y
BR2_OPTIMIZE_S=y

# --- Init / post-build ---
BR2_INIT_NONE=y
# BR2_INIT_TINYINIT is not set
BR2_ROOTFS_POST_BUILD_SCRIPT="board/stmicroelectronics/common/stm32f4xx/stm32-post-build.sh"

# --- Global patch directory (board-specific kernel patches) ---
BR2_GLOBAL_PATCH_DIR="board/stmicroelectronics/stm32f429-disco/patches"

# --- Linux kernel (XIP from on-chip flash) ---
BR2_LINUX_KERNEL=y
BR2_LINUX_KERNEL_CUSTOM_VERSION=y
BR2_LINUX_KERNEL_CUSTOM_VERSION_VALUE="7.0"
BR2_LINUX_KERNEL_USE_CUSTOM_CONFIG=y
BR2_LINUX_KERNEL_CUSTOM_CONFIG_FILE="board/stmicroelectronics/stm32f429-disco/linux.config"
BR2_LINUX_KERNEL_IMAGE_TARGET_CUSTOM=y
BR2_LINUX_KERNEL_IMAGE_TARGET_NAME="xipImage"
BR2_LINUX_KERNEL_DTS_SUPPORT=y
BR2_LINUX_KERNEL_INTREE_DTS_NAME="st/stm32f429-disco"

# --- Bootloader (afboot-stm32, XIP kernel in flash) ---
BR2_TARGET_AFBOOT_STM32=y
BR2_TARGET_AFBOOT_STM32_KERNEL_ADDR=0x0800C000

# --- Busybox (minimal config from /tmp) ---
BR2_PACKAGE_BUSYBOX=y
BR2_PACKAGE_BUSYBOX_CONFIG_FRAGMENT_FILES="board/stmicroelectronics/common/stm32f4xx/busybox.fragment"

# --- Zlib (for adbd zipfile APK inflation) ---
BR2_PACKAGE_ZLIB=y

# --- Filesystem images ---
# romfs is used as the initfs in flash (loaded by kernel at boot).
# ext2 is built for the TF card rootfs (mounted by custom init).
BR2_TARGET_ROOTFS_EXT2=y
# BR2_TARGET_ROOTFS_TAR is not set
BR2_TARGET_ROOTFS_ROMFS=y

# --- Host tools ---
BR2_PACKAGE_HOST_OPENOCD=y
BR2_PACKAGE_GENROMFS=y

# --- Misc packages ---
# BR2_PACKAGE_IFUPDOWN_SCRIPTS is not set
BR2_PACKAGE_URANDOM_SCRIPTS=y

# --- adbd package (defined in package/adbd/) ---
BR2_PACKAGE_ADBD=y

# --- echo_gadget package (defined in package/echo_gadget/) ---
BR2_PACKAGE_ECHO_GADGET=y