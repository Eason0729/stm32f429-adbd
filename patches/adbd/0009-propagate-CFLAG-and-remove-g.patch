From e06131d3c20155c6bd25f3bb211788a7d9b0cf2f Mon Sep 17 00:00:00 2001
From: =?UTF-8?q?=E9=82=B1=E7=B9=BC=E5=8F=A1=20Eason=20CHIU?=
 <30045503+Eason0729@users.noreply.github.com>
Date: Mon, 22 Jun 2026 17:25:34 +0800
Subject: [PATCH 8/8] propagate CFLAG and remove -g

---
 adb/Makefile             | 6 +++---
 base/Makefile            | 3 +--
 config.mk                | 4 ++--
 include.mk               | 6 ++++--
 libcrypto_utils/Makefile | 2 +-
 libcutils/Makefile       | 4 ++--
 6 files changed, 13 insertions(+), 12 deletions(-)

diff --git a/adb/Makefile b/adb/Makefile
index db74cf44f..25c52e42c 100644
--- a/adb/Makefile
+++ b/adb/Makefile
@@ -72,15 +72,15 @@ CXXFLAGS = $(OPT_CXXFLAGS) -std=c++14 $(LOCAL_CFLAGS) $(LOCAL_INCLUDES)
 CFLAGS= $(OPT_CFLAGS) $(LOCAL_CFLAGS) $(LOCAL_INCLUDES)
 
 %.o: %.cpp
-	$(CXX) -g -c -fPIC $(CXXFLAGS) $(LFLAGS) $< -o $@
+	$(CXX) -c $(PIC_FLAGS) $(CXXFLAGS) $(LFLAGS) $< -o $@
 
 %.o: %.c
-	$(CC) -g -c -fPIC $(CFLAGS) $(LFLAGS) $< -o $@
+	$(CC) -c $(PIC_FLAGS) $(CFLAGS) $(LFLAGS) $< -o $@
 
 all: $(LOCAL_MODULE)
 
 $(LOCAL_MODULE): $(OBJS)
-	$(CXX) -fPIC $(CXXFLAGS) $(LFLAGS) $^ \
+	$(CXX) $(PIC_FLAGS) $(CXXFLAGS) $(LFLAGS) $^ \
 		../libcutils/*.o ../base/*.o ../libcrypto_utils/*.o \
 		-lpthread -lresolv -o $@
 
diff --git a/base/Makefile b/base/Makefile
index 2e33396f4..5c724fd5f 100644
--- a/base/Makefile
+++ b/base/Makefile
@@ -39,7 +39,7 @@ CXXFLAGS += -DPROP_NAME_MAX=32 -DPROP_VALUE_MAX=92
 all: $(LOCAL_MODULE)
 
 %.o: %.cpp
-	$(CXX) -g -c -fPIC $(CXXFLAGS) $(LFLAGS) $< -o $@
+	$(CXX) -c $(PIC_FLAGS) $(CXXFLAGS) $(LFLAGS) $< -o $@
 
 $(LOCAL_MODULE): $(OBJS)
 	ar rcs $@ $?
@@ -47,4 +47,3 @@ $(LOCAL_MODULE): $(OBJS)
 
 clean:
 	rm -f $(LOCAL_MODULE) *.o
-
diff --git a/config.mk b/config.mk
index 95bb9c03a..d0515fd20 100644
--- a/config.mk
+++ b/config.mk
@@ -5,6 +5,6 @@ bindir = $(prefix)/bin
 datadir = $(prefix)/share
 mandir = $(datadir)/man
 sysconfdir = $(prefix)/etc
-OPT_CFLAGS = -O2 -g
-OPT_CXXFLAGS = -O2 -g
+OPT_CFLAGS ?= -O2
+OPT_CXXFLAGS ?= -O2
 ADB_NOMMU = true
diff --git a/include.mk b/include.mk
index 8f1959127..cbff39e43 100644
--- a/include.mk
+++ b/include.mk
@@ -8,8 +8,10 @@ sbindir ?= $(exec_prefix)/sbin
 datadir ?= $(prefix)/share
 mandir ?= $(datadir)/man
 sysconfdir ?= $(prefix)/etc
-OPT_CFLAGS ?= -O2 -g
-OPT_CXXFLAGS ?= -O2 -g
+OPT_CFLAGS ?= -O2
+OPT_CXXFLAGS ?= -O2
+export OPT_CFLAGS OPT_CXXFLAGS
+PIC_FLAGS ?= -fPIC
 ADB_NOMMU ?= 0
 CC ?= gcc
 CXX ?= g++
diff --git a/libcrypto_utils/Makefile b/libcrypto_utils/Makefile
index 201968aa3..54f04e741 100644
--- a/libcrypto_utils/Makefile
+++ b/libcrypto_utils/Makefile
@@ -15,7 +15,7 @@ CFLAGS += -DPROP_NAME_MAX=32 -DPROP_VALUE_MAX=92
 all: $(LOCAL_MODULE)
 
 %.o: %.c
-	$(CC) -g -c -fPIC $(CFLAGS) $(LFLAGS) $< -o $@
+	$(CC) -c $(PIC_FLAGS) $(CFLAGS) $(LFLAGS) $< -o $@
 
 $(LOCAL_MODULE): $(OBJS)
 	ar rcs $@ $?
diff --git a/libcutils/Makefile b/libcutils/Makefile
index 941f4998a..ed7631c45 100644
--- a/libcutils/Makefile
+++ b/libcutils/Makefile
@@ -59,10 +59,10 @@ CXXFLAGS = $(OPT_CXXFLAGS) $(EXTRA_CFLAGS)
 all: $(LOCAL_MODULE)
 
 %.o: %.cpp
-	$(CXX) -c -fPIC $(CXXFLAGS) $(LFLAGS) $< -o $@
+	$(CXX) -c $(PIC_FLAGS) $(CXXFLAGS) $(LFLAGS) $< -o $@
 
 %.o: %.c
-	$(CC) -c -fPIC $(CFLAGS) $(LFLAGS) $< -o $@
+	$(CC) -c $(PIC_FLAGS) $(CFLAGS) $(LFLAGS) $< -o $@
 
 $(LOCAL_MODULE): $(OBJS)
 	ar rcs $@ $?
-- 
2.54.0

