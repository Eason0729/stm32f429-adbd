From: =?UTF-8?q?=E9=82=B1=E7=B9=BC=E5=8F=A1=20Eason=20CHIU?=
 <30045503+Eason0729@users.noreply.github.com>
Date: Thu, 25 Jun 2026 13:18:57 +0800
Subject: [PATCH] resize sync service buffer on the fly

---
 adb/file_sync_service.cpp | 10 ++++------
 1 file changed, 4 insertions(+), 6 deletions(-)

diff --git a/adb/file_sync_service.cpp b/adb/file_sync_service.cpp
index ec5853101..c769fe962 100644
--- a/adb/file_sync_service.cpp
+++ b/adb/file_sync_service.cpp
@@ -242,9 +242,8 @@ static bool handle_send_file(sync_fd s, const char* path, uid_t uid, gid_t gid,
             goto abort;
         }
 
-        if (msg.data.size > buffer.size()) {  // TODO: resize buffer?
-            SendSyncFail(s, "oversize data message");
-            goto abort;
+        if (msg.data.size > buffer.size()) {
+            buffer.resize(msg.data.size);
         }
 
         if (!ReadFdExactly(s.rfd, &buffer[0], msg.data.size)) goto abort;
@@ -317,9 +316,8 @@ static bool handle_send_link(sync_fd s, const std::string& path, std::vector<cha
     }
 
     len = msg.data.size;
-    if (len > buffer.size()) { // TODO: resize buffer?
-        SendSyncFail(s, "oversize data message");
-        return false;
+    if (len > buffer.size()) {
+        buffer.resize(len);
     }
     if (!ReadFdExactly(s.rfd, &buffer[0], len)) return false;
 
-- 
