From 194bb2a028cb8c12f5daa2c5b6d33e200fd82bda Mon Sep 17 00:00:00 2001
From: =?UTF-8?q?=E9=82=B1=E7=B9=BC=E5=8F=A1=20Eason=20CHIU?=
 <30045503+Eason0729@users.noreply.github.com>
Date: Sat, 20 Jun 2026 12:28:32 +0800
Subject: [PATCH] Enable noMMU build by introduce CC and CCX

---
 adb/Makefile             | 13 ++++++++-----
 base/Makefile            |  4 ++--
 config.mk                | 10 ++++++++++
 configure                |  6 ++++++
 include.mk               |  8 ++++++++
 libcrypto_utils/Makefile |  4 ++--
 libcutils/Makefile       |  6 +++---
 7 files changed, 39 insertions(+), 12 deletions(-)
 create mode 100644 config.mk

diff --git a/adb/Makefile b/adb/Makefile
index 82b2d7ca8..09e0b9c1c 100644
--- a/adb/Makefile
+++ b/adb/Makefile
@@ -54,6 +54,7 @@ LOCAL_CFLAGS := -DADB_HOST=0 -Wall -Wno-unused-parameter
 LOCAL_CFLAGS += -D_XOPEN_SOURCE -D_GNU_SOURCE -DHAVE_PTHREADS=1
 LOCAL_CFLAGS += -DADB_NON_ANDROID=1 -DADB_REVISION='"$(adb_version)"'
 LOCAL_CFLAGS += -DPROP_NAME_MAX=32 -DPROP_VALUE_MAX=92 -DALLOW_ADBD_NO_AUTH=1
+LOCAL_CFLAGS += $(ADB_NOMMU_DEFINE)
 LOCAL_INCLUDES := -I$(top_srcdir)/include -I$(top_srcdir)/base/include/ -I$(top_srcdir)/libcrypto_utils/include/ -I$(srcdir)
 
 LOCAL_MODULE := adbd
@@ -71,18 +72,20 @@ CXXFLAGS = $(OPT_CXXFLAGS) -std=c++14 $(LOCAL_CFLAGS) $(LOCAL_INCLUDES)
 CFLAGS= $(OPT_CFLAGS) $(LOCAL_CFLAGS) $(LOCAL_INCLUDES)
 
 %.o: %.cpp
-	g++ -g -c -fPIC $(CXXFLAGS) $(LFLAGS) $< -o $@
+	$(CXX) -g -c -fPIC $(CXXFLAGS) $(LFLAGS) $< -o $@
 
 %.o: %.c
-	gcc -g -c -fPIC $(CFLAGS) $(LFLAGS) $< -o $@
+	$(CC) -g -c -fPIC $(CFLAGS) $(LFLAGS) $< -o $@
 
-all: $(LOCAL_MODULE) xdg-adbd
+all: $(LOCAL_MODULE)
 
 $(LOCAL_MODULE): $(OBJS)
-	g++ -fPIC $(CXXFLAGS) $^ -L ../libcutils/*.o ../base/*.o ../libcrypto_utils/*.o -lpthread -lresolv -lcrypto -lssl -lutil -o $@
+	$(CXX) -fPIC $(CXXFLAGS) $(LFLAGS) $^ \
+		../libcutils/*.o ../base/*.o ../libcrypto_utils/*.o \
+		-lpthread -lresolv -latomic -o $@
 
 xdg-adbd: xdg-adbd.c
-	gcc -o $@ $< $(CFLAGS) $(LFLAGS) `pkg-config --libs --cflags glib-2.0`
+	$(CC) -o $@ $< $(CFLAGS) $(LFLAGS) `pkg-config --libs --cflags glib-2.0`
 
 clean:
 	rm -f $(LOCAL_MODULE) xdg-adbd *.o daemon/*.o
diff --git a/base/Makefile b/base/Makefile
index bb5a906c7..2e33396f4 100644
--- a/base/Makefile
+++ b/base/Makefile
@@ -33,13 +33,13 @@ LOCAL_CFLAGS += $(targetSmpFlag)
 ################################
 
 OBJS = $(LOCAL_SRC_FILES:.cpp=.o)
-CXXFLAGS = $(OPT_CXXFLAGS) -std=c++0x $(LOCAL_CFLAGS) -I$(top_srcdir)/include/ -I$(srcdir)/include -I$(srcdir) -DHAVE_PTHREADS=1 -DADB_NON_ANDROID=1
+CXXFLAGS = $(OPT_CXXFLAGS) -std=c++0x $(LOCAL_CFLAGS) -I$(top_srcdir)/include/ -I$(srcdir)/include -I$(srcdir) -DHAVE_PTHREADS=1 -DADB_NON_ANDROID=1 $(ADB_NOMMU_DEFINE)
 CXXFLAGS += -DPROP_NAME_MAX=32 -DPROP_VALUE_MAX=92
 
 all: $(LOCAL_MODULE)
 
 %.o: %.cpp
-	g++ -g -c -fPIC $(CXXFLAGS) $(LFLAGS) $< -o $@
+	$(CXX) -g -c -fPIC $(CXXFLAGS) $(LFLAGS) $< -o $@
 
 $(LOCAL_MODULE): $(OBJS)
 	ar rcs $@ $?
diff --git a/config.mk b/config.mk
new file mode 100644
index 000000000..95bb9c03a
--- /dev/null
+++ b/config.mk
@@ -0,0 +1,10 @@
+prefix = /usr
+exec_prefix = $(prefix)
+sbindir = $(exec_prefix)/sbin
+bindir = $(prefix)/bin
+datadir = $(prefix)/share
+mandir = $(datadir)/man
+sysconfdir = $(prefix)/etc
+OPT_CFLAGS = -O2 -g
+OPT_CXXFLAGS = -O2 -g
+ADB_NOMMU = true
diff --git a/configure b/configure
index a95aca9f5..e18ebc718 100755
--- a/configure
+++ b/configure
@@ -15,6 +15,7 @@ print_help() {
     echo "--docdir=DIR		Install documentation files in DIR (default DATADIR/doc/tgt)"
     echo "--sbindir=DIR		Install binaries in DIR (default DATADIR/sbin)"
     echo "--disable-man         Disable building and installing man pages"
+    echo "--enable-nommu        Build for noMMU Linux (uClibc/uClinux); use posix_spawn instead of fork"
 }
 
 top_srcdir=$(dirname $0)
@@ -28,6 +29,7 @@ mandir='$(datadir)/man'
 sysconfdir='$(prefix)/etc'
 CFLAGS='-O2 -g'
 CXXFLAGS='-O2 -g'
+nommu=false
 
 while [ $# '>' 0 ] ; do
     option=`expr "$1" : '\([^=]*\)='`
@@ -72,6 +74,9 @@ while [ $# '>' 0 ] ; do
             ;;
         --with-*|--without-*|--enable-*|--disable-*)
             consume_next=false
+            case "$option" in
+                --enable-nommu) nommu=true ;;
+            esac
             ;;
         --help)
             print_help
@@ -94,6 +99,7 @@ mandir = $mandir
 sysconfdir = $sysconfdir
 OPT_CFLAGS = $CFLAGS
 OPT_CXXFLAGS = $CXXFLAGS
+ADB_NOMMU = $nommu
 EOF
 
 if [ "$(pwd)" != "$(cd $top_srcdir && pwd)" ] ; then
diff --git a/include.mk b/include.mk
index 075815b4e..8f1959127 100644
--- a/include.mk
+++ b/include.mk
@@ -10,3 +10,11 @@ mandir ?= $(datadir)/man
 sysconfdir ?= $(prefix)/etc
 OPT_CFLAGS ?= -O2 -g
 OPT_CXXFLAGS ?= -O2 -g
+ADB_NOMMU ?= 0
+CC ?= gcc
+CXX ?= g++
+
+# Internal helper: non-empty when building for noMMU Linux.
+ifneq ($(ADB_NOMMU),0)
+ADB_NOMMU_DEFINE = -DADB_NOMMU=1
+endif
diff --git a/libcrypto_utils/Makefile b/libcrypto_utils/Makefile
index e642e5e35..201968aa3 100644
--- a/libcrypto_utils/Makefile
+++ b/libcrypto_utils/Makefile
@@ -9,13 +9,13 @@ LOCAL_MODULE = libcrypto_utils.a
 ################################
 
 OBJS = $(LOCAL_SRC_FILES:.c=.o)
-CFLAGS = $(OPT_CFLAGS) $(LOCAL_CFLAGS) -I$(top_srcdir)/include/ -I$(srcdir)/include/ -I$(srcdir) -DHAVE_PTHREADS=1 -DADB_NON_ANDROID=1
+CFLAGS = $(OPT_CFLAGS) $(LOCAL_CFLAGS) -I$(top_srcdir)/include/ -I$(srcdir)/include/ -I$(srcdir) -DHAVE_PTHREADS=1 -DADB_NON_ANDROID=1 $(ADB_NOMMU_DEFINE)
 CFLAGS += -DPROP_NAME_MAX=32 -DPROP_VALUE_MAX=92
 
 all: $(LOCAL_MODULE)
 
 %.o: %.c
-	gcc -g -c -fPIC $(CFLAGS) $(LFLAGS) $< -o $@
+	$(CC) -g -c -fPIC $(CFLAGS) $(LFLAGS) $< -o $@
 
 $(LOCAL_MODULE): $(OBJS)
 	ar rcs $@ $?
diff --git a/libcutils/Makefile b/libcutils/Makefile
index 9e6e4000d..941f4998a 100644
--- a/libcutils/Makefile
+++ b/libcutils/Makefile
@@ -51,7 +51,7 @@ LOCAL_CFLAGS += $(targetSmpFlag)
 ################################
 
 OBJS = $(LOCAL_SRC_FILES:.c=.o) $(LOCAL_CXX_SRC_FILES:.cpp=.o)
-EXTRA_CFLAGS = $(LOCAL_CFLAGS) -I$(top_srcdir)/include -I$(srcdir) -DHAVE_PTHREADS=1 -DADB_NON_ANDROID=1
+EXTRA_CFLAGS = $(LOCAL_CFLAGS) -I$(top_srcdir)/include -I$(srcdir) -DHAVE_PTHREADS=1 -DADB_NON_ANDROID=1 $(ADB_NOMMU_DEFINE)
 EXTRA_CFLAGS += -DPROP_NAME_MAX=32 -DPROP_VALUE_MAX=92
 CFLAGS = $(OPT_CFLAGS) $(EXTRA_CFLAGS)
 CXXFLAGS = $(OPT_CXXFLAGS) $(EXTRA_CFLAGS)
@@ -59,10 +59,10 @@ CXXFLAGS = $(OPT_CXXFLAGS) $(EXTRA_CFLAGS)
 all: $(LOCAL_MODULE)
 
 %.o: %.cpp
-	g++ -c -fPIC $(CXXFLAGS) $(LFLAGS) $< -o $@
+	$(CXX) -c -fPIC $(CXXFLAGS) $(LFLAGS) $< -o $@
 
 %.o: %.c
-	gcc -c -fPIC $(CFLAGS) $(LFLAGS) $< -o $@
+	$(CC) -c -fPIC $(CFLAGS) $(LFLAGS) $< -o $@
 
 $(LOCAL_MODULE): $(OBJS)
 	ar rcs $@ $?
-- 
2.54.0

