From: stm32f429-adbd
Date: Sun, 3 May 2026 00:00:00 +0800
Subject: Switch from SDIO to SPI4 MMC card, disable display and
 I2C3 touch

---
  arch/arm/boot/dts/st/stm32f429-disco.dts  | 13 insertions(+), 16 deletions(-)
  arch/arm/boot/dts/st/stm32f4-pinctrl.dtsi | 14 insertions(+), 0 deletions(-)
  2 files changed, 27 insertions(+), 16 deletions(-)

diff --git a/arch/arm/boot/dts/st/stm32f429-disco.dts b/arch/arm/boot/dts/st/stm32f429-disco.dts
index cda8a951d..1b5228f84 100644
@@ -147,15 +147,19 @@
 	clock-frequency = <8000000>;
 };
 
-&sdio {
+&spi4 {
 	status = "okay";
-	pinctrl-names = "default", "opendrain";
-	pinctrl-0 = <&sdio_pins>;
-	pinctrl-1 = <&sdio_pins_od>;
-	bus-width = <1>;
-	max-frequency = <1000000>;
-	broken-cd;
-	vmmc-supply = <&v3v3>;
+	pinctrl-names = "default";
+	pinctrl-0 = <&spi4_pins>;
+	cs-gpios = <&gpioe 4 GPIO_ACTIVE_LOW>;
+
+	mmc-slot@0 {
+		compatible = "mmc-spi-slot";
+		reg = <0>;
+		spi-max-frequency = <12000000>;
+		voltage-ranges = <3000 3500>;
+		broken-cd;
+	};
 };
 
 &crc {
@@ -166,7 +170,7 @@
 	pinctrl-names = "default";
 	pinctrl-0 = <&i2c3_pins>;
 	clock-frequency = <100000>;
-	status = "okay";
+	status = "disabled";
 
 	stmpe811@41 {
 		compatible = "st,stmpe811";
@@ -208,7 +212,7 @@
 };
 
 &ltdc {
-	status = "okay";
+	status = "disabled";
 	pinctrl-0 = <&ltdc_pins_b>;
 	pinctrl-names = "default";
 
@@ -275,12 +275,4 @@
 	pinctrl-0 = <&usart1_pins_a>;
 	pinctrl-names = "default";
 	status = "okay";
 };
-
-&usbotg_hs {
-	compatible = "st,stm32f4x9-fsotg";
-	dr_mode = "host";
-	pinctrl-0 = <&usbotg_fs_pins_b>;
-	pinctrl-names = "default";
-	status = "okay";
-};

diff --git a/arch/arm/boot/dts/st/stm32f4-pinctrl.dtsi b/arch/arm/boot/dts/st/stm32f4-pinctrl.dtsi
index befe48909..92f9c5b93 100644
@@ -382,6 +392,20 @@
 				};
 			};
 
+			spi4_pins: spi4-0 {
+				pins1 {
+					pinmux = <STM32_PINMUX('E', 2, AF5)>, /* SPI4_SCK */
+						 <STM32_PINMUX('E', 6, AF5)>; /* SPI4_MOSI */
+					bias-disable;
+					drive-push-pull;
+					slew-rate = <0>;
+				};
+				pins2 {
+					pinmux = <STM32_PINMUX('E', 5, AF5)>; /* SPI4_MISO */
+					bias-pull-up;
+				};
+			};
+
 			i2c3_pins: i2c3-0 {
 				pins {
 					pinmux = <STM32_PINMUX('C', 9, AF4)>,
