From 84be1e748571ba6dfaa3aa412da9328c25f00b74 Mon Sep 17 00:00:00 2001
From: Chisheng Chen <johnny1001s000602@gmail.com>
Date: Fri, 1 May 2026 19:24:53 +0800
Subject: [PATCH 9/9] Change back to romfs as an initfs

---
 arch/arm/boot/dts/st/stm32f429-disco.dts | 18 ++++++++++++++++---
 1 file changed, 15 insertions(+), 3 deletions(-)

diff --git a/arch/arm/boot/dts/st/stm32f429-disco.dts b/arch/arm/boot/dts/st/stm32f429-disco.dts
index 34d6cdd1a..cda8a951d 100644
--- a/arch/arm/boot/dts/st/stm32f429-disco.dts
+++ b/arch/arm/boot/dts/st/stm32f429-disco.dts
@@ -58,7 +58,7 @@ / {
 	compatible = "st,stm32f429i-disco", "st,stm32f429";
 
 	chosen {
-		bootargs = "root=/dev/mmcblk0 rootwait rootfstype=ext2 ro";
+        bootargs = "root=mtd:romfs rootfstype=romfs ro init=/init";
 		stdout-path = "serial0:115200n8";
 	};

@@ -73,9 +73,21 @@ flash@8000000 {
 		bank-width = <4>;
 		#address-cells = <1>;

+		partition@0 {
+			label = "afboot";
+			reg = <0x0 0x4000>;
+		};
+		partition@4000 {
+			label = "dtb";
+			reg = <0x4000 0x8000>;
+		};
+		partition@C000 {
+			label = "xipimage";
+			reg = <0xC000 0x184000>;
+		};
-		partition@18d000 {
+		partition@190000 {
 			label = "romfs";
-			reg = <0x18d000 0x73000>;
+			reg = <0x190000 0x70000>;
 		};
 	};
 
