From: stm32f429-adbd
Date: Sun, 21 Jun 2026 22:57:09 +0800
Subject: adbd: update to noMMU fork HEAD, add start_adbd.sh

---
 .../common/stm32f4xx/start_adbd.sh            | 32 +++++++++++++++++++
 .../common/stm32f4xx/stm32-post-build.sh      |  3 ++
 2 files changed, 35 insertions(+)
 create mode 100755 board/stmicroelectronics/common/stm32f4xx/start_adbd.sh

diff --git a/board/stmicroelectronics/common/stm32f4xx/start_adbd.sh b/board/stmicroelectronics/common/stm32f4xx/start_adbd.sh
new file mode 100755
index 0000000..1b1b8bc
--- /dev/null
+++ b/board/stmicroelectronics/common/stm32f4xx/start_adbd.sh
@@ -0,0 +1,32 @@
+#!/bin/sh
+
+GADGET=/sys/kernel/config/usb_gadget/g1
+
+# 1. Create gadget if not exists
+if [ ! -d "$GADGET" ]; then
+    mkdir -p "$GADGET"
+    echo 0x18d1 > "$GADGET"/idVendor
+    echo 0x4E26 > "$GADGET"/idProduct
+    mkdir -p "$GADGET"/strings/0x409
+    cat /sys/class/net/eth0/address 2>/dev/null \
+        > "$GADGET"/strings/0x409/serialnumber
+    echo "ST" > "$GADGET"/strings/0x409/manufacturer
+    echo "STM32" > "$GADGET"/strings/0x409/product
+    mkdir -p "$GADGET"/functions/ffs.adb
+    mkdir -p "$GADGET"/configs/c.1/strings/0x409
+    echo "adb" > "$GADGET"/configs/c.1/strings/0x409/configuration
+    echo 120 > "$GADGET"/configs/c.1/MaxPower
+    ln -sf "$GADGET"/functions/ffs.adb "$GADGET"/configs/c.1/f1
+fi
+
+# 2. Mount functionfs
+mkdir -p /dev/usb-ffs/adb
+mount -t functionfs adb /dev/usb-ffs/adb 2>/dev/null
+
+# 3. Start adbd (opens ep0, writes descriptors)
+adbd &
+
+# 4. Wait for adbd to init, then enable UDC
+sleep 3
+UDC=$(ls /sys/class/udc)
+echo "$UDC" > "$GADGET"/UDC
diff --git a/board/stmicroelectronics/common/stm32f4xx/stm32-post-build.sh b/board/stmicroelectronics/common/stm32f4xx/stm32-post-build.sh
index c2e0930..461de3b 100755
--- a/board/stmicroelectronics/common/stm32f4xx/stm32-post-build.sh
+++ b/board/stmicroelectronics/common/stm32f4xx/stm32-post-build.sh
@@ -26,6 +26,9 @@ rm -f "${TARGET_DIR}/usr/lib/libssl.so"*
 rm -f "${TARGET_DIR}/usr/lib/ossl-modules/legacy.so"
 rmdir "${TARGET_DIR}/usr/lib/ossl-modules" 2>/dev/null || true
 
+# Install USB gadget init script for adbd
+install -D -m 0755 "$(dirname "$0")/start_adbd.sh" "${TARGET_DIR}/usr/bin/start_adbd.sh"
+
 TARGET_STRIP="${TARGET_DIR}/../host/bin/arm-buildroot-uclinuxfdpiceabi-strip"
 if [ -x "${TARGET_STRIP}" ]; then
     if [ -d "${TARGET_DIR}/lib" ]; then
