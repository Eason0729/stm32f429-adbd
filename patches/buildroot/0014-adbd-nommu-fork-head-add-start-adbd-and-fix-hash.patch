+################################################################################
+#
+# adbd
+#
+################################################################################
+
+ADBD_VERSION = 07f091cd595d61555bb857096532c8a9d7d81291
+ADBD_SITE = https://github.com/arduino/adbd.git
+ADBD_SITE_METHOD = git
+ADBD_LICENSE = Apache-2.0
+ADBD_LICENSE_FILES = MODULE_LICENSE_APACHE2 NOTICE
+
+# adbd uses a hand-written Makefile system, so we build and install it
+# manually. The Makefiles use CC/CXX/AR/RANLIB from the environment.
+ADBD_MAKE_ENV = \
+	CC="$(TARGET_CC)" \
+	CXX="$(TARGET_CXX)" \
+	AR="$(TARGET_AR)" \
+	RANLIB="$(TARGET_RANLIB)" \
+	STRIP="$(TARGET_STRIP)" \
+	ADB_NOMMU=1 \
+	OPT_CFLAGS="$(TARGET_CFLAGS) \
+		-Os \
+		-ffunction-sections -fdata-sections \
+		-fno-unwind-tables -fno-asynchronous-unwind-tables \
+		-Wno-deprecated-declarations -DALLOW_ADBD_NO_AUTH=1" \
+	OPT_CXXFLAGS="$(TARGET_CXXFLAGS) \
+		-Os \
+		-ffunction-sections -fdata-sections \
+		-fno-exceptions -fno-rtti \
+		-fno-unwind-tables -fno-asynchronous-unwind-tables \
+		-std=gnu++14 \
+		-Wno-deprecated-declarations -DALLOW_ADBD_NO_AUTH=1" \
+	LFLAGS="$(TARGET_LDFLAGS) \
+		-static \
+		-Wl,--gc-sections \
+		-Wl,--no-eh-frame-hdr \
+		-latomic"
+
+define ADBD_BUILD_CMDS
+	$(ADBD_MAKE_ENV) $(MAKE) -C $(@D) all
+endef
+
+define ADBD_INSTALL_TARGET_CMDS
+	$(INSTALL) -D -m 0755 $(@D)/adb/adbd $(TARGET_DIR)/usr/bin/adbd
+	$(INSTALL) -D -m 0755 $(ADBD_PKGDIR)/adbd-watch.sh $(TARGET_DIR)/usr/bin/adbd-watch.sh
+endef
+
+$(eval $(generic-package))
