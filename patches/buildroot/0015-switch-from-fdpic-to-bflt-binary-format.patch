From: stm32f429-adbd
Date: Mon, 22 Jun 2026 12:00:00 +0800
Subject: Switch from FDPIC to bFLT binary format

Switch the target strip tool from the FDPIC variant to the bFLT
variant and harden busybox strip against failure.

---
 .../common/stm32f4xx/stm32-post-build.sh           | 14 ++++++++------
 1 file changed, 8 insertions(+), 6 deletions(-)

diff --git a/board/stmicroelectronics/common/stm32f4xx/stm32-post-build.sh b/board/stmicroelectronics/common/stm32f4xx/stm32-post-build.sh
index 319f3bf..3c0dda4 100755
--- a/board/stmicroelectronics/common/stm32f4xx/stm32-post-build.sh
+++ b/board/stmicroelectronics/common/stm32f4xx/stm32-post-build.sh
@@ -25,14 +25,14 @@ rm -f "${TARGET_DIR}/usr/lib/libssl.so"*
 rm -f "${TARGET_DIR}/usr/lib/ossl-modules/legacy.so"
 rmdir "${TARGET_DIR}/usr/lib/ossl-modules" 2>/dev/null || true
 
-TARGET_STRIP="${TARGET_DIR}/../host/bin/arm-buildroot-uclinuxfdpiceabi-strip"
+TARGET_STRIP="${TARGET_DIR}/../host/bin/arm-buildroot-uclinux-uclibcgnueabi-strip"
 if [ -x "${TARGET_STRIP}" ]; then
     if [ -d "${TARGET_DIR}/lib" ]; then
         find "${TARGET_DIR}/lib" -name "*.so*" -type f -exec "${TARGET_STRIP}" --strip-unneeded {} + 2>/dev/null || true
     fi
 
     if [ -f "${TARGET_DIR}/bin/busybox" ]; then
-        "${TARGET_STRIP}" --strip-unneeded "${TARGET_DIR}/bin/busybox"
+        "${TARGET_STRIP}" --strip-unneeded "${TARGET_DIR}/bin/busybox" 2>/dev/null || true
     fi
 fi
